PORT=3001
AWS_REGION=us-east-1

# --- MANDATORY SECURITY SETTINGS ---
# Use a random 32+ character string. In production, the server will error if this is not set.
JWT_SECRET=change-this-to-a-random-32-char-string-in-production

# Required for first-run admin seeding. Must be at least 12 characters.
ADMIN_INITIAL_PASSWORD=change-this-to-a-strong-password-12chars-min

# Set to 'production' to enable: secure cookies, sanitized errors, and mandatory JWT_SECRET check
NODE_ENV=development

# --- SES / OTP CONFIGURATION ---
# AWS SES region (where your email identity is verified — often different from app region)
SES_REGION=us-east-1
# AWS SES email for forgot-password OTP delivery (domain must be verified in SES)
SES_FROM_EMAIL=noreply@yourdomain.com

# --- FRONTEND ---
# CRITICAL FOR PRODUCTION: Set this to your CloudFront domain (comma-separated for multiple).
# If this is wrong, the browser will get CORS errors on all API requests.
# Example production value: https://dji1sh2llkd41.cloudfront.net
# Example local dev value:   http://localhost:5173
FRONTEND_URL=http://localhost:5173

# --- AWS SERVICE CONFIG ---
COST_EXPLORER_CACHE_TTL=21600
REPORTS_S3_BUCKET=cloudsense-reports-YOUR_ACCOUNT_ID
SNS_ALERT_TOPIC_ARN=arn:aws:sns:us-east-1:YOUR_ACCOUNT_ID:cloudsense-alerts
LAMBDA_REPORT_FUNCTION=cloudsense-report-generator
